---
title: Sessions
permalink: /sessions/index.html
layout: page
sections:
  none:
    title: Not about AI
    open: true
  ai:
    title: AI Sessions
    open: false
---
{% set groupedSessions = sessions | groupby("list") %}
{% set categoriesById = categories | toObject("id") %}

<p>
  Be sure to visit the official site and mark yourself as interested in any sessions that catch your eye.
</p>
<p>
  <strong>Audience interest determines the schedule</strong> and who gets assigned to the larger rooms.
</p>

{% for type, block in sections %}
  <details {{ "open" if block.open }}>
    <summary style="font-family: var(--font-display); font-size: var(--size-step-2);">{{block.title}}</summary>

    <ul>
      {% for session in groupedSessions[type] %}
        <li>
          <p>
            <a href={{ session.url }}>
              {{ session.title }}
            </a>
          </p>
          <p class="cluster gutter-xs-s" style="font-size: var(--size-step-min-1); color: var(--color-text-accent);">
            {% set comma = joiner() %}
            {% for speaker in session.speakers -%}
              {{ comma() }} {{ speaker.speakerName }}
            {%- endfor %}
            {% for categoryId in session.categories %}
              <a
                class="button"
                data-small-button
                style="
                  text-transform: none;
                  --button-font-size: var(--size-step-min-2);
                  --button-bg: var(--color-bg-accent);
                  --button-color: var(--color-text-accent);
                  --button-border-color: var(--color-bg-accent-2);
                  --button-hover-bg: var(--color-secondary);
                  --button-hover-color: var(--color-text);
                "
                href="/categories/{{ categoryId }}/"
              >
                {{ categoriesById[categoryId].name }}
              </a>
            {% endfor %}
          </p>
        </li>
      {% endfor %}
    </ul>
  </details>
{% endfor %}
